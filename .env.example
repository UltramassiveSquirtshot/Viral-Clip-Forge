# Copy this file to .env and fill in your values

# Required: YouTube Data API v3 key
# Get one at: https://console.cloud.google.com/ → APIs & Services → YouTube Data API v3
YOUTUBE_API_KEY=your_api_key_here

# Optional: override FFmpeg/ffprobe paths (auto-detected if on PATH)
FFMPEG_BIN=C:\Users\Utente\AppData\Local\Microsoft\WinGet\Packages\Gyan.FFmpeg_Microsoft.Winget.Source_8wekyb3d8bbwe\ffmpeg-8.1.1-full_build\bin\ffmpeg.exe
FFPROBE_BIN=C:\Users\Utente\AppData\Local\Microsoft\WinGet\Packages\Gyan.FFmpeg_Microsoft.Winget.Source_8wekyb3d8bbwe\ffmpeg-8.1.1-full_build\bin\ffprobe.exe

# Optional: override output directories
# OUTPUT_DIR=C:\Users\Utente\Desktop\PROGETTI\Viral Clip Forge\clips
# DOWNLOAD_DIR=C:\Users\Utente\Desktop\PROGETTI\Viral Clip Forge\downloads
# STATE_DB_PATH=C:\Users\Utente\Desktop\PROGETTI\Viral Clip Forge\data\state.db
# LOG_DIR=C:\Users\Utente\Desktop\PROGETTI\Viral Clip Forge\logs

# Optional: clip tuning
# MAX_CLIPS_PER_VIDEO=3
# MIN_CLIP_DURATION=30
# MAX_CLIP_DURATION=90
# SCENE_THRESHOLD=0.40
# AUDIO_PEAK_PERCENTILE=85
# MIN_VIEWS=50000
# MAX_VIDEO_DURATION=1800

# Telegram notifications — get token from @BotFather, chat_id from @userinfobot
TELEGRAM_BOT_TOKEN=your_bot_token_here
TELEGRAM_CHAT_ID=your_chat_id_here

# Human-in-the-loop approval
# When true (default), clips are cut into clips/pending/<run_id>/ and the run
# stays "pending" until approved with `python main.py --approve <run_id>`
# (or discarded with `--reject <run_id>`). Set to false once you trust the
# pipeline's selections and want it to publish clips straight to clips/.
REQUIRE_APPROVAL=true

# Ranking Shorts (ranker.py) — stock footage + background music API keys
# Pexels (free): https://www.pexels.com/api/  ·  Pixabay (free): https://pixabay.com/api/docs/
PEXELS_API_KEY=your_pexels_api_key_here
PIXABAY_API_KEY=your_pixabay_api_key_here
# Optional overrides for the ranker's own Google Drive OAuth (separate from analytics)
# RANKER_GDRIVE_TOKEN_PATH=C:\Users\Utente\Desktop\PROGETTI\Viral Clip Forge\data\ranker_gdrive_token.json
# RANKER_CLIENT_SECRET_PATH=C:\Users\Utente\Desktop\PROGETTI\Viral Clip Forge\data\ranker_client_secret.json

# AI Shorts (aishorts) — fully-synthetic images + edge-TTS narrator format.
# Reuses the ranker's Drive OAuth token (full drive scope). No new API keys.
# Optional edge-TTS voice (default en-US-AriaNeural). Browse voices: `edge-tts --list-voices`
# AISHORTS_VOICE=en-US-AriaNeural
